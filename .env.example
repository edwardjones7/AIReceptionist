# ─────────────────────────────────────────────────────────────────────────
# Scarlett — environment template. Copy to .env.local and fill in.
# NEVER commit .env.local. All of these are server-side only.
# ─────────────────────────────────────────────────────────────────────────

# DEV FALLBACK ONLY. In production each request resolves its tenant from the
# Vapi assistant id against the tenants table in Supabase (npm run seed).
# This selects which tenant to fall back to when no DB row matches
# (file in config/<TENANT>.tenant.json).
TENANT=elenos

# Public base URL of THIS app once deployed (used in the Vapi provision script
# to point the assistant's custom-LLM + tool + webhook URLs back here).
# Local dev with a tunnel: e.g. https://scarlett.ngrok.app
PUBLIC_BASE_URL=https://your-deployment.vercel.app

# Shared secret Vapi must send on every request to our endpoints.
# Set the same value in the Vapi assistant server config (see README).
VAPI_SERVER_SECRET=generate-a-long-random-string

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=sk-ant-...
# Model for live, latency-sensitive turns. Haiku 4.5 = fast + cheap.
LLM_MODEL=claude-haiku-4-5
# Model for the offline after-call summary (latency irrelevant).
SUMMARY_MODEL=claude-sonnet-4-6

# ── Vapi ──
VAPI_API_KEY=...
# Set after first provision run, or let the script print it.
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# ── Supabase ──
SUPABASE_URL=https://xxxx.supabase.co
# Service-role key — server only, full DB access. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=...
# Anon (publishable) key — used only server-side for client-portal magic-link
# auth (/portal). Supabase dashboard → Settings → API.
SUPABASE_ANON_KEY=...
# Postgres schema for Scarlett's tables. Leave unset (defaults to "public") for
# a standalone project. Set to "scarlett" when co-locating in the shared Elenos
# database — then run supabase/elenos-scarlett-schema.sql and add "scarlett" to
# Supabase → Settings → API → Exposed schemas.
SUPABASE_DB_SCHEMA=public

# ── Google Calendar (service account with domain-wide delegation OR a
#    calendar shared to the service account email). See README for setup. ──
GOOGLE_CLIENT_EMAIL=scarlett@your-project.iam.gserviceaccount.com
# Paste the private key with literal \n escapes, or base64 — see lib/google-calendar.ts
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# DEV FALLBACK ONLY — production tenants carry their own calendar_id on the
# tenants row. The calendar that discovery calls land on for the fallback tenant.
GOOGLE_CALENDAR_ID=edjjones07@gmail.com

# ── Twilio (number + SMS alerts + call transfer) ──
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# The Twilio number Scarlett answers on (E.164)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Notifications — DEV FALLBACK ONLY ──
# Production tenants carry notify_phone / owner_numbers / discord_webhook_url
# on their tenants row (set via the admin dashboard or npm run seed).
# Founder's cell — used for (1) SMS alerts + transfer target, AND (2) FOUNDER MODE:
# when this number calls in, Scarlett recognizes it and becomes an internal
# executive assistant (metrics, leads, bookings, calendar) instead of a receptionist.
FOUNDER_CELL=+1XXXXXXXXXX
# Optional: extra internal numbers that also get founder mode (comma-separated, E.164)
FOUNDER_NUMBERS=
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Admin dashboard (/admin) ──
# Password you log in with, and a long random string used to sign the session cookie.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=generate-another-long-random-string
